# ==============================================================================
# FIT 2026 — CONFIGURAÇÃO DO SERVIDOR (APACHE / UNIVERSIDADE)
# URL Rewrite para ocultar extensões .html e manter links amigáveis (Pretty URLs)
# ==============================================================================

RewriteEngine On
RewriteBase /

# 1. Forçar a remoção da extensão .html da barra de endereços (Redirecionamento 301)
# Suporta qualquer subdiretório automaticamente capturando o caminho original
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.html\ HTTP
RewriteRule ^([^.]+)\.html$ /%1 [R=301,L]

# 2. Servir silenciosamente o arquivo .html correspondente se a URL digitada não tiver extensão
# Exemplo: Acessar '/links' serve o conteúdo de '/links.html'
# Exemplo: Acessar '/auth/login' serve o conteúdo de '/auth/login.html'
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
