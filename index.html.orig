    <!-- Firebase SDK -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.10.0/firebase-app.js";
        import { getFirestore, collection, getDocs, query, orderBy } from "https://www.gstatic.com/firebasejs/12.10.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyAOGVRFFgUoYA8MvDkaIjGumNzEkGzcEHY",
            authDomain: "fit-crateus.firebaseapp.com",
            projectId: "fit-crateus",
            storageBucket: "fit-crateus.firebasestorage.app",
            messagingSenderId: "88037686885",
            appId: "1:88037686885:web:53e6860fa068e003ac908c"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);

        // Load Palestrantes
        async function loadSpeakers() {
            const container = document.getElementById('speakers-grid');
            if (!container) return;
            try {
                const q = query(collection(db, 'palestrantes'), orderBy('ordem'));
                const snapshot = await getDocs(q);
                if (snapshot.empty) return; // Keep static fallback
                container.innerHTML = '';
                snapshot.forEach(docSnap => {
                    const d = docSnap.data();
                    const card = document.createElement('div');
                    card.className = 'speaker-card';
                    card.innerHTML = `
                        <div class="speaker-photo">
                            ${d.foto ? `<img src="${d.foto}" alt="${d.nome}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">` : '<i class="fas fa-user-circle"></i>'}
                        </div>
                        <h4>${d.nome}</h4>
                        <p class="speaker-role">${d.cargo || 'Palestrante'}</p>
                        <p class="speaker-topic">${d.tema || ''}</p>
                    `;
                    container.appendChild(card);
                });
            } catch (err) {
                console.error('Firestore speakers error:', err);
            }
        }

        // Load Patrocinadores
        async function loadSponsors() {
            const container = document.getElementById('sponsors-container');
            if (!container) return;
            try {
                const q = query(collection(db, 'patrocinadores'), orderBy('ordem'));
                const snapshot = await getDocs(q);
                if (snapshot.empty) return; // Keep static fallback

                const tiers = { diamante: [], prata: [], midia: [] };
                snapshot.forEach(docSnap => {
                    const d = docSnap.data();
                    if (tiers[d.tier]) tiers[d.tier].push(d);
                });

                container.innerHTML = '';
                const tierConfig = [
                    { key: 'diamante', title: 'Diamante', icon: 'fa-gem', class: 'tier-diamante', cardClass: 'sponsor-diamante-card' },
                    { key: 'prata', title: 'Prata', icon: 'fa-medal', class: 'tier-prata', cardClass: 'sponsor-prata-card' },
                    { key: 'midia', title: 'Apoio de Mídia', icon: 'fa-newspaper', class: 'tier-midia', cardClass: 'sponsor-midia-card' }
                ];

                tierConfig.forEach(tier => {
                    if (tiers[tier.key].length === 0) return;
                    const section = document.createElement('div');
                    section.className = 'sponsor-tier';
                    section.innerHTML = `
                        <h3 class="tier-title ${tier.class}"><i class="fas ${tier.icon}"></i> ${tier.title}</h3>
                        <div class="sponsors-grid sponsors-${tier.key}"></div>
                    `;
                    const grid = section.querySelector('.sponsors-grid');
                    tiers[tier.key].forEach(s => {
                        const card = document.createElement('div');
                        card.className = `sponsor-card ${tier.cardClass}`;
                        card.innerHTML = s.logo
                            ? `<img src="${s.logo}" alt="${s.nome}" style="max-width:80%;max-height:60%;object-fit:contain;">`
                            : `<span>${s.nome}</span>`;
                        grid.appendChild(card);
                    });
                    container.appendChild(section);
                });
            } catch (err) {
                console.error('Firestore sponsors error:', err);
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadSpeakers();
            loadSponsors();
        });
    </script>

